# MoltsPay Server Configuration
# Copy this file to ~/.moltspay/.env and fill in your values

# ============================================
# Network Configuration
# ============================================
# Set to 'true' for Base mainnet, 'false' for Base Sepolia testnet
# Testnet doesn't require CDP credentials (uses public x402.org facilitator)
USE_MAINNET=false

# ============================================
# CDP (Coinbase Developer Platform) Credentials
# Required for MAINNET only
# Get these from: https://portal.cdp.coinbase.com/
# ============================================
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ============================================
# Server Configuration (Optional)
# ============================================
# Skill execution timeout in seconds (default: 1200 = 20 minutes)
# SKILL_TIMEOUT_SECONDS=1200

# ============================================
# Solana Relay Fee Payer
# ============================================
# Private key for paying Solana transaction fees (base58 encoded)
# Required for server-side settlement on Solana chains
# SOLANA_FEE_PAYER_KEY=

# ============================================
# BNB Chain Relay Fee Payer
# ============================================
# Private key for paying BNB Chain transaction fees
# Required for server-side settlement on BNB chains (bsc, opbnb)
# BNB_SERVER_PRIVATE_KEY=
